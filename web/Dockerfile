# ---- Stage 1: build ----
# This stage has Node and all the dev dependencies. It produces /app/dist.
FROM node:22-alpine AS build

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# ---- Stage 2: serve ----
# A brand new, tiny image. Node, npm, and node_modules are all left behind --
# only the built static files come across. This is a "multi-stage build".
FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
